# ============ SMTP / EMAIL (para redefinição de senha) ============
# Configure um provedor SMTP (Gmail, SendGrid, Mailgun, etc.) ou use credenciais do seu servidor SMTP.
# Exemplo (substitua pelos valores reais no Railway / .env):
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=seu_usuario_smtp
SMTP_PASS=sua_senha_smtp
EMAIL_FROM="Conecta Saude <no-reply@seudominio.com>"

# URL do frontend (usada no link enviado por email). Ajuste para produção ou para o endereço do Expo dev quando testar.
FRONTEND_URL=https://planodeassinatura-production.up.railway.app
# Link de deep link para app móvel (opcional). Usado para abrir o app com token.
APP_DEEP_LINK=meusistema://reset-password

