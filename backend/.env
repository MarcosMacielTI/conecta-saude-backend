# ⚠️ NÃO COMITE CREDENCIAIS REAIS AQUI
# Substitua estes valores no Railway (ou arquivo .env local — não versionado)

MONGO_URI=mongodb+srv://usuario:senha@cluster.mongodb.net/conecta_saude?retryWrites=true&w=majority
JWT_SECRET=seu_jwt_secret_aqui_substitua_no_railway
GOOGLE_CLIENT_ID=seu_google_client_id_aqui
GOOGLE_CLIENT_SECRET=seu_google_client_secret_aqui
REDIRECT_URI=https://auth.expo.io/@seu_usuario/seu_app
PORT=3000

# ============ SEGURANÇA ============
# Gerar com: node -e "const crypto = require('crypto'); console.log(crypto.randomBytes(32).toString('hex'))"
ENCRYPTION_KEY=seu_encryption_key_aqui_substitua_no_railway

# API Key para chamadas internas (cron jobs, webhooks internos)
INTERNAL_API_KEY=sua_internal_api_key_aqui_substitua_no_railway

# ============ MERCADO PAGO ============
MERCADO_PAGO_ACCESS_TOKEN=seu_mercado_pago_token_aqui
MERCADO_PAGO_PUBLIC_KEY=seu_mercado_pago_public_key_aqui
MERCADO_PAGO_WEBHOOK_SECRET=seu_webhook_secret_aqui

# Backend Base URL (para webhooks)
BACKEND_BASE_URL=https://planodeassinatura-production.up.railway.app

# ============ AMBIENTE ============
NODE_ENV=production

# ============ SMTP / EMAIL (para redefinição de senha) ============
# Configure um provedor SMTP (Gmail, SendGrid, Mailgun, etc.) ou use credenciais do seu servidor SMTP.
# Exemplo (substitua pelos valores reais no Railway / .env):
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=seu_usuario_smtp
SMTP_PASS=sua_senha_smtp
EMAIL_FROM="Conecta Saude <no-reply@seudominio.com>"

# URL do frontend (usada no link enviado por email). Ajuste para produção ou para o endereço do Expo dev quando testar.
FRONTEND_URL=https://planodeassinatura-production.up.railway.app

# Observações:
# - Não comite credenciais reais no repositório. Configure as variáveis secretas no Railway/Host.
# - Se usar Gmail, crie uma senha de app ou use um provedor dedicado (SendGrid/Mailgun) para produção.

